.divWidget {
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;

  background-color: rgba(0, 0, 0, 0.75);

  .container {
    width: 35%;
    height: fit-content;
    space-between-entries: 15;

    left: 50%;
    top: 50%;

    alignment-x: center;
    alignment-y: center;

    padding: 10;

    .title {
      alignment-x: center;
    }

    .buttonDivWidget {

      padding: 10;

      .buttonContainer {
        width: 75%;
        height: fit-content;
        alignment-x: center;
        alignment-y: center;
        layout: fill;
        space-between-entries: 40;

        .submit {
          padding-left: 40;
          padding-right: 40;
        }

        .cancel {
          padding-left: 20;
          padding-right: 20;
        }
      }
    }
  }
}